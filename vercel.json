{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/products/:slug",
      "destination": "/product.html"
    },
    {
      "source": "/categories/:slug",
      "destination": "/category.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
